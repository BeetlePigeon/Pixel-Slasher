{
  "id": "homing_bolt",

  "spawn": {
    "static_tiles": "reject"
  },

  "motion": {
    "type": "linear",
    "speed": 334,
    "influence_mode": "normal"
  },

  "lifetime_ticks": 600,

  "sprite": {
    "image": "ice_shard",
    "anchor": "center",
    "z": 0
  },

  "blocks_movement": false,
  "movement_footprint": "single_tile",
  "contact_footprint": "single_tile",

  "movement_collision": {
    "static_tiles": "block",
    "dynamic_blockers": "allow"
  },

  "impact_responses": {
    "projectile_static_impact": "destroy_self",
    "projectile_dynamic_actor_contact": "destroy_self"
  },

  "collides_with_relationship": "enemies",

  "behaviors": [
    {
      "type": "homing",
      "targeting": {
        "mode": "explicit_target_else_none",
        "relationship": "enemies",
        "explicit_target_max_range_tiles": 50,
        "requires": ["hittable", "health"]
      },
      "retarget": {
        "mode": "nearest_when_no_target",
        "relationship": "enemies",
        "radius_tiles": 4,
        "requires": ["hittable", "health"]
      },
      "turn_rate_steps_per_tick": 1
    }
  ],

  "effect_triggers": [
    {
      "event": "projectile_dynamic_actor_contact",
      "effect_deliveries": [
        {
          "activation": {
            "type": "immediate"
          },
          "selection": {
            "type": "contact_target"
          },
          "filtering": {
            "requires": ["hittable", "health"]
          },
          "payloads": [
            {
              "type": "damage",
              "params": {
                "amount": 2,
                "damage_type": "cold"
              }
            }
          ]
        }
      ],
      "effect_carrier_lifecycle": {
        "destroy_when": "effect_deliveries_complete"
      }
    }
  ],

  "influence_receiver": {
    "accepts": ["wind", "magnet"],
    "scales": {
      "wind": [1, 1],
      "magnet": [1, 1]
    },
    "max_delta_tile_units_divisor": 8
  }
}