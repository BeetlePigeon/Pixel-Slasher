{
  "id": "flame_hazard",

  "spawn": {
    "static_tiles": "reject"
  },

  "motion": {
    "type": "static"
  },

  "lifetime_ticks": 2480,

  "sprite": {
    "image": "flame_hazard",
    "anchor": "bottom_center",
    "z": 0
  },

  "blocks_movement": false,
  "movement_footprint": "single_tile",
  "contact_footprint": "plus5",

  "movement_collision": {
    "static_tiles": "allow",
    "dynamic_blockers": "allow"
  },

  "impact_responses": {
    "projectile_dynamic_actor_contact": "continue"
  },

  "contact_cadence": {
    "type": "per_target_cooldown",
    "cooldown_ticks": 20
  },

  "ignore_source": true,
  "collides_with_relationship": "enemies",

  "effect_triggers": [
    {
      "event": "projectile_dynamic_actor_contact",
      "effect_deliveries": [
        {
          "activation": {
            "type": "immediate"
          },
          "selection": {
            "type": "contact_target"
          },
          "filtering": {
            "requires": ["hittable", "health"]
          },
          "payloads": [
            {
              "type": "damage",
              "params": {
                "amount": 1,
                "damage_type": "fire"
              }
            }
          ]
        }
      ],
      "effect_carrier_lifecycle": {
        "destroy_when": "effect_deliveries_complete"
      }
    }
  ]
}