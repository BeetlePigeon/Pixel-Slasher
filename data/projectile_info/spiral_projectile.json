{
  "id": "spiral_projectile",

  "spawn": {
    "static_tiles": "reject"
  },

  "motion": {
    "type": "spiral",
    "radius_per_tick": 128,
    "angle_step_fp": 256,
    "spawn_angle_step_offset": 0,
    "influence_mode": "ignore_all"
  },

  "lifetime_ticks": 300,

  "sprite": {
    "image": "test_projectile",
    "anchor": "center",
    "z": 0
  },

  "blocks_movement": false,
  "movement_footprint": "plus5",
  "contact_footprint": "plus5",

  "movement_collision": {
    "static_tiles": "block",
    "dynamic_blockers": "allow"
  },

  "impact_responses": {
    "projectile_static_impact": "destroy_self",
    "projectile_dynamic_actor_contact": "destroy_self"
  },

  "collides_with_relationship": "enemies",
  "effect_triggers": [
    {
      "event": "projectile_dynamic_actor_contact",
      "effect_deliveries": [
        {
          "activation": {
            "type": "immediate"
          },
          "selection": {
            "type": "contact_target"
          },
          "filtering": {
            "requires": ["hittable", "health"]
          },
          "payloads": [
            {
              "type": "damage",
              "params": {
                "amount": 8,
                "damage_type": "arcane"
              }
            }
          ]
        }
      ],
      "effect_carrier_lifecycle": {
        "destroy_when": "effect_deliveries_complete"
      }
    }
  ],

  "influence_receiver": {
    "accepts": ["wind", "magnet"],
    "scales": {
      "wind": [1, 1],
      "magnet": [1, 1]
    },
    "max_delta_tile_units_divisor": 8
  }
}