{
  "id": "fireball",

  "motion": {
    "type": "linear",
    "speed": 512,
    "influence_mode": "normal"
  },
  "lifetime_ticks": 300,

  "sprite": {
    "image": "fireball",
    "anchor": "center",
    "z": 0
  },

  "movement_footprint": "plus5",
  "contact_footprint": "plus5",

  "movement_collision": {
    "static_tiles": "block",
    "dynamic_blockers": "allow"
  },

  "impact_responses": {
    "projectile_static_impact": "destroy_self",
    "projectile_dynamic_actor_contact": "destroy_self"
  },

  "collides_with_relationship": "enemies",

  "influence_receiver": {
    "accepts": ["wind", "magnet"],
    "scales": {
      "wind": [1, 1],
      "magnet": [1, 1]
    },
    "max_delta_tile_units_divisor": 8
  },

  "effect_triggers": [
    {
      "event": "projectile_dynamic_actor_contact",
      "effect_deliveries": [
        {
          "activation": {
            "type": "immediate"
          },
          "selection": {
            "type": "tiles",
            "shape": {
              "type": "square",
              "radius_tiles": 2
            }
          },
          "filtering": {
            "relationship": "enemies",
            "requires": ["hittable", "health"],
            "include_source": false
          },
          "payloads": [
            {
              "type": "damage",
              "params": {
                "amount": 4,
                "damage_type": "fire"
              }
            }
          ]
        }
      ],
      "effect_carrier_lifecycle": {
        "destroy_when": "effect_deliveries_complete"
      }
    },
    {
      "event": "projectile_static_impact",
      "effect_deliveries": [
        {
          "activation": {
            "type": "immediate"
          },
          "selection": {
            "type": "tiles",
            "shape": {
              "type": "square",
              "radius_tiles": 3
            }
          },
          "filtering": {
            "relationship": "enemies",
            "requires": ["hittable", "health"],
            "include_source": false
          },
          "payloads": [
            {
              "type": "damage",
              "params": {
                "amount": 4,
                "damage_type": "fire"
              }
            }
          ]
        }
      ],
      "effect_carrier_lifecycle": {
        "destroy_when": "effect_deliveries_complete"
      }
    }
  ]
}