{
  "id": "fireball_projectile",
  "name": "Fireball Projectile",
  "cooldown_ticks": 0,
  "trigger_mode": "held_repeat",

  "blocked_by_motion_tags": ["dash"],
  "blocked_by_action_tags": [
    "cast",
    "channel",
    "recovery",
    "stun",
    "skill_locked"
  ],
  "cancels_action_tags": [],

  "required_components": ["transform"],
  "required_params": [
    "spawn_distance",
    "projectile_speed",
    "projectile_lifetime",
    "effect_triggers",
    "collides_with_teams",
    "movement_footprint",
    "contact_footprint",
    "contact_response"
  ],

  "allowed_param_values": {},

  "aim": {
    "traditional_source": "mouse_tile",
    "modern_source": "mouse_tile",
    "resolution": "tile_center"
  },

  "cast": {
    "duration": 20,
    "tags": ["cast", "movement_locked", "skill_locked"],
    "events": [
      {
        "tick": 10,
        "handler": "execute_test_projectile"
      }
    ]
  },

  "channel": null,

  "params": {
    "spawn_distance": 1024,
    "projectile_speed": 512,
    "projectile_lifetime": 300,
    "effect_triggers": [
      {
        "event": "projectile_dynamic_actor_contact",
        "effect_deliveries": [
          {
            "activation": {
              "type": "immediate"
            },
            "selection": {
              "type": "tiles",
              "shape": {
                "type": "square",
                "radius_tiles": 2
              }
            },
            "filtering": {
              "relationship": "enemies",
              "requires": ["hittable", "health"],
              "include_source": false
            },
            "payloads": [
              {
                "type": "damage",
                "params": {
                  "amount": 4,
                  "damage_type": "fire"
                }
              }
            ]
          }
        ],
        "effect_carrier_lifecycle": {
          "destroy_when": "effect_deliveries_complete"
        }
      },
      {
        "event": "projectile_static_impact",
        "effect_deliveries": [
          {
            "activation": {
              "type": "immediate"
            },
            "selection": {
              "type": "tiles",
              "shape": {
                "type": "square",
                "radius_tiles": 3
              }
            },
            "filtering": {
              "relationship": "enemies",
              "requires": ["hittable", "health"],
              "include_source": false
            },
            "payloads": [
              {
                "type": "damage",
                "params": {
                  "amount": 4,
                  "damage_type": "fire"
                }
              }
            ]
          }
        ],
        "effect_carrier_lifecycle": {
          "destroy_when": "effect_deliveries_complete"
        }
      }
    ],

    "collides_with_teams": ["enemy"],

    "movement_footprint": "plus5",
    "contact_footprint": "plus5",

    "contact_response": {
      "dynamic_actor": "destroy_self"
    }
  },

  "handler": "execute_cast_skill"
}