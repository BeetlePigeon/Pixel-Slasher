{
  "id": "meteor",
  "name": "Meteor",
  "cooldown_ticks": 0,
  "trigger_mode": "held_repeat",

  "blocked_by_motion_tags": ["dash"],
  "blocked_by_action_tags": [
    "cast",
    "channel",
    "recovery",
    "stun",
    "skill_locked"
  ],
  "cancels_action_tags": [],

  "required_components": ["transform"],
  "required_params": [
    "placement_search_radius",
    "placement_max_miss_tiles",
    "effect_deliveries",
    "effect_carrier_lifecycle",
    "visual"
  ],

  "allowed_param_values": {},

  "aim": null,

  "cast": {
    "type": "cast",
    "duration": 35,
    "tags": ["cast", "movement_locked", "skill_locked"],
    "phases": [
      {
        "name": "startup",
        "start": 0,
        "end": 20,
        "tags": ["cast", "movement_locked", "skill_locked"]
      },
      {
        "name": "release",
        "start": 20,
        "end": 30,
        "tags": ["cast", "movement_locked", "skill_locked"]
      },
      {
        "name": "recovery",
        "start": 30,
        "end": 35,
        "tags": ["recovery", "skill_locked"]
      }
    ],
    "events": [
      {
        "tick": 24,
        "handler": "execute_meteor"
      }
    ]
  },

  "channel": null,

  "params": {
    "placement_search_radius": 2,
    "placement_max_miss_tiles": 2,
    "effect_deliveries": [
      {
      "activation": {
        "type": "once",
        "tick": 75
      },
      "selection": {
        "type": "tiles",
        "shape": {
          "type": "square",
          "radius_tiles": 2
        }
      },
      "filtering": {
        "relationship": "enemies",
        "requires": ["hittable"],
        "include_source": false
      },
      "payloads": [
        {
          "type": "damage",
          "params": {
            "amount": 2,
            "damage_type": "fire"
          }
        }
      ]
      },
      {
      "activation": {
        "type": "once",
        "tick": 75
      },
      "payloads": [
        {
          "type": "spawn_projectiles",
          "params": {
            "projectile_id": "flame_hazard",
            "origin": "carrier",
            "pattern": {
              "type": "tile_offsets",
              "offsets": [
                [-1, -1],
                [1, 1],
                [-2, -2],
                [-3, -2],
                [-4, -2],
                [-1, -3],
                [0, -4],
                [1, -3],
                [2, -1],
                [2, -2],
                [3, -3],
                [4, -2],
                [0, 2],
                [0, 3],
                [0, 5],
                [-1, 2],
                [-3, 3],
                [3, 3]
              ]
            }
          }
        }
      ]
    }
    ],
    "effect_carrier_lifecycle": {
      "destroy_when": "effect_deliveries_complete"
    },
    "visual": {
      "image": "meteor",
      "anchor": "center",
      "z": 0
    }
  },
  "handler": "execute_cast_skill"
}