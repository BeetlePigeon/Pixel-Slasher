{
  "id": "meteor",
  "name": "Meteor",
  "cooldown_ticks": 0,
  "trigger_mode": "held_repeat",

  "blocked_by_motion_tags": ["dash"],
  "blocked_by_action_tags": [
    "cast",
    "channel",
    "recovery",
    "stun",
    "skill_locked"
  ],
  "cancels_action_tags": [],

  "required_components": ["transform"],
  "required_params": [
    "placement_search_radius",
    "placement_max_miss_tiles",
    "effect_delivery",
    "lifetime",
    "visual"
  ],

  "allowed_param_values": {},

  "aim": null,

  "cast": {
    "type": "cast",
    "duration": 35,
    "tags": ["cast", "movement_locked", "skill_locked"],
    "phases": [
      {
        "name": "startup",
        "start": 0,
        "end": 20,
        "tags": ["cast", "movement_locked", "skill_locked"]
      },
      {
        "name": "release",
        "start": 20,
        "end": 30,
        "tags": ["cast", "movement_locked", "skill_locked"]
      },
      {
        "name": "recovery",
        "start": 30,
        "end": 35,
        "tags": ["recovery", "skill_locked"]
      }
    ],
    "events": [
      {
        "tick": 24,
        "handler": "execute_meteor"
      }
    ]
  },

  "channel": null,

  "params": {
    "placement_search_radius": 2,
    "placement_max_miss_tiles": 2,
    "lifetime": 90,
    "effect_delivery": {
      "delivery": {
        "type": "timed_tiles",
        "trigger": {
          "type": "once",
          "tick": 75
        },
        "shape": {
          "type": "square",
          "radius_tiles": 2
        }
      },
      "targeting": {
        "relationship": "enemies",
        "requires": ["hittable"],
        "include_source": false
      },
      "payloads": [
        {
          "type": "damage",
          "params": {
            "amount": 2,
            "damage_type": "fire"
          }
        }
      ],
      "consume_policy": {
        "destroy_carrier_after_delivery": true
      }
    },
    "visual": {
      "image": "meteor",
      "anchor": "center",
      "z": 0
    }
  },

  "handler": "execute_cast_skill"
}