{
  "id": "pierce_projectile",
  "name": "Pierce Projectile",
  "cooldown_ticks": 0,
  "trigger_mode": "held_repeat",

  "blocked_by_motion_tags": ["dash"],
  "blocked_by_action_tags": [
    "cast",
    "channel",
    "recovery",
    "stun",
    "skill_locked"
  ],
  "cancels_action_tags": [],

  "required_components": ["transform"],
  "required_params": [
    "spawn_distance",
    "projectile_speed",
    "projectile_lifetime",
    "effect_triggers",
    "collides_with_teams",
    "contact_footprint",
    "contact_response",
    "contact_cadence"
  ],

  "allowed_param_values": {},

  "aim": {
    "traditional_source": "mouse_tile",
    "modern_source": "mouse_tile",
    "resolution": "tile_center"
  },

  "cast": {
    "duration": 16,
    "tags": ["cast", "movement_locked", "skill_locked"],
    "events": [
      {
        "tick": 10,
        "handler": "execute_test_projectile"
      }
    ]
  },

  "channel": null,

  "params": {
    "spawn_distance": 1024,
    "projectile_speed": 512,
    "projectile_lifetime": 300,

    "effect_triggers": [
      {
        "event": "projectile_dynamic_actor_contact",
        "effect_deliveries": [
          {
            "activation": {
              "type": "immediate"
            },
            "selection": {
              "type": "contact_target"
            },
            "filtering": {
              "requires": ["hittable", "health"]
            },
            "payloads": [
              {
                "type": "damage",
                "params": {
                  "amount": 2,
                  "damage_type": "physical"
                }
              }
            ]
          }
        ],
        "effect_carrier_lifecycle": {
          "destroy_when": "effect_deliveries_complete"
        }
      }
    ],

    "collides_with_teams": ["enemy"],
    "contact_footprint": "plus5",
    "contact_response": {
      "dynamic_actor": "continue"
    },
    "contact_cadence": {
      "type": "once_per_projectile"
    }
  },

  "handler": "execute_cast_skill"
}